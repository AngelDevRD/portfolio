# =========================================================
#  Variables de entorno — copia este archivo a .env.local
#  y rellena tus claves reales. NUNCA subas .env.local a git.
# =========================================================

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Resend (envío de correos: contacto y sugerencias) ---
# Crea tu API key en https://resend.com/api-keys
RESEND_API_KEY=
# Correo verificado en Resend desde el que se envía (ej. web@tudominio.com)
CONTACT_FROM_EMAIL=onboarding@resend.dev
# Tu correo donde quieres RECIBIR los mensajes
CONTACT_TO_EMAIL=angeldnielgs@gmail.com

# --- Supabase (base de datos de sugerencias + auth del admin) ---
# Panel: https://supabase.com/dashboard  -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave de servicio (solo servidor, NUNCA con NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# --- Panel de administración ---
# Contraseña simple para el panel /admin (v1). Cambiar en producción.
ADMIN_PASSWORD=changeme

# --- GitHub (lectura de releases/metadata de las apps del catalogo) ---
# Personal access token de solo lectura, evita rate-limit bajo de la API publica.
GITHUB_TOKEN=

# --- Orquestador de apps (webhook de Codemagic, ver src/app/api/orchestrator/webhook) ---
# Debe coincidir con el valor $WEBHOOK_SECRET del grupo "portfolio_release" en Codemagic.
WEBHOOK_SECRET=
# PAT fine-grained de SOLO LECTURA (Contents:Read-only), scope a los repos Flutter en
# alcance (appgym/nexfit, finanzas360, mi-negocio, appviewamine/anivault). Solo lee
# pubspec.yaml/README/manifest/Info.plist/assets para auto-completar el catalogo -- nunca escribe.
METADATA_GH_TOKEN=
# PAT fine-grained con Contents:Read-and-write, scope UNICAMENTE a este repo (protafolioweb).
# Es el unico que comitea content/projects/mobile/*.json y public/metadata.json.
# Principio de minimo privilegio: distinto de METADATA_GH_TOKEN (no lee los repos Flutter) y
# distinto de RELEASE_GH_TOKEN (que vive solo en Codemagic y nunca toca este repo).
PORTFOLIO_GH_TOKEN=
